# Required: Groq API key used by all LLM agents
GROQ_API_KEY=your_groq_api_key_here

# Optional: Groq HTTP client (Fix #6 — timeouts / retries for all agents + API filename helper)
# GROQ_REQUEST_TIMEOUT=120
# GROQ_MAX_RETRIES=2
# GROQ_MODEL=llama-3.3-70b-versatile

# Optional: DuckDuckGo search retries in tools/search_tools.py
# WEB_SEARCH_MAX_ATTEMPTS=3
# WEB_SEARCH_BACKOFF_SEC=0.6
# If a query returns fewer than this many DDGS rows, retry a broader DDGS query then Wikipedia (opensearch).
# WEB_SEARCH_SPARSE_THRESHOLD=3

# Optional: Fix #8 / #10 / #12 — POST /research uses PIPELINE_API_KEY only when set.
# GET /reports* accepts PIPELINE_API_KEY or PIPELINE_REPORTS_API_KEY (read-only viewer key).
# PIPELINE_API_KEY=your_long_random_secret
# PIPELINE_REPORTS_API_KEY=optional_shorter_read_key
# RESEARCH_RATE_LIMIT=30/minute
# READ_REPORTS_RATE_LIMIT=120/minute

# Optional: enable LangSmith tracing/observability
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=your_langsmith_api_key_here
# LANGSMITH_PROJECT=multi-agent-pipeline
